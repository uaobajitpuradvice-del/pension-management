<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PPO SYNC - BAJITPUR PRO</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            --glass-bg: rgba(255, 255, 255, 0.95);
            --text-main: #1e293b;
        }

        body {
            font-family: 'Poppins', 'Hind Siliguri', sans-serif;
            background: #f1f5f9;
            color: var(--text-main);
            min-height: 100vh;
            padding-top: 210px;
        }

        /* Fixed Top Section */
        .fixed-top-container {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1030;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            padding-bottom: 15px;
        }

        .navbar {
            background: #1e293b !important;
            margin: 10px 20px;
            border-radius: 15px;
            padding: 8px 25px;
        }

        .office-header {
            text-align: center;
            font-weight: 800;
            font-size: 1.6rem;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 5px 0;
        }

        /* Stats & Search */
        .control-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .mini-stat {
            background: #f8fafc;
            padding: 6px 15px;
            border-radius: 10px;
            font-size: 0.8rem;
            font-weight: 700;
            border: 1px solid #e2e8f0;
            display: flex;
            gap: 8px;
        }

        .compact-search-box {
            width: 350px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 8px 15px;
            font-weight: 600;
            outline: none;
            transition: 0.3s;
        }

        .compact-search-box:focus { border-color: #6366f1; box-shadow: 0 0 8px rgba(99, 102, 241, 0.2); }

        /* Table CSS */
        .main-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin: 0 20px 50px 20px;
            overflow: hidden;
        }

        .table { margin-bottom: 0; }
        
        /* Table Text Centered & Header */
        .table thead th {
            background: #1e293b !important;
            color: white !important;
            text-align: center; /* Header Centered */
            padding: 15px;
            font-size: 0.9rem;
            border: none;
        }

        .table tbody td {
            text-align: center; /* All Data Centered */
            vertical-align: middle;
            padding: 15px;
            font-weight: 500;
            border-bottom: 1px solid #f1f5f9;
        }

        /* Status Badge */
        .badge-custom {
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
        }
        .status-stocked { background: #dcfce7; color: #166534; }
        .status-delivered { background: #fee2e2; color: #991b1b; }

        .btn-action { width: 32px; height: 32px; border-radius: 8px; border: none; margin: 0 2px; }
        .btn-edit { background: #e0e7ff; color: #4338ca; }
        .btn-delete { background: #fee2e2; color: #dc2626; }

        #loadingOverlay {
            display: none; position: fixed; inset: 0; z-index: 9999; 
            background: rgba(255,255,255,0.8);
            flex-direction: column; justify-content: center; align-items: center;
        }

        @media print { .no-print, .fixed-top-container { display: none !important; } body { padding-top: 0; } }
    </style>
</head>
<body>

<div id="loadingOverlay">
    <div class="spinner-border text-primary"></div>
    <h6 class="mt-3 fw-bold">সিঙ্ক হচ্ছে...</h6>
</div>

<div class="fixed-top-container no-print">
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <span class="navbar-brand fw-bold"><i class="bi bi-cloud-check-fill me-2"></i>PPO SYNC PRO</span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light" onclick="clearForm()" data-bs-toggle="modal" data-bs-target="#entryModal">নতুন এন্ট্রি</button>
                <button class="btn btn-sm btn-warning fw-bold" onclick="fetchFromCloud()">সিঙ্ক ক্লাউড</button>
                <button class="btn btn-sm btn-light" onclick="exportTableToExcel()"><i class="bi bi-file-earmark-excel"></i></button>
            </div>
        </div>
    </nav>

    <div class="office-header">উপজেলা হিসাবরক্ষণ অফিস, বাজিতপুর</div>

    <div class="control-bar">
        <div class="d-flex gap-2">
            <div class="mini-stat">মোট: <span id="statTotal">0</span></div>
            <div class="mini-stat text-success">মজুদ: <span id="statStocked">0</span></div>
            <div class="mini-stat text-danger">বিতরণকৃত: <span id="statDelivered">0</span></div>
        </div>
        <div class="position-relative">
            <input type="text" id="searchBox" class="compact-search-box" placeholder="খুঁজুন (নাম বা PPO)..." oninput="currentPage=1; updateUI()">
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="main-card">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="width: 25%;">পেনশনারের নাম</th>
                    <th style="width: 15%;">PPO নম্বর</th>
                    <th style="width: 15%;">সিরিয়াল নং</th>
                    <th style="width: 15%;">অবস্থা</th>
                    <th style="width: 20%;">মন্তব্য</th>
                    <th style="width: 10%;" class="no-print">অ্যাকশন</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                <!-- Data will load here -->
            </tbody>
        </table>
        <div class="p-3 border-top bg-light">
            <nav><ul class="pagination pagination-sm justify-content-center mb-0" id="pagination"></ul></nav>
        </div>
    </div>
</div>

<!-- Entry Modal -->
<div class="modal fade" id="entryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow border-0" style="border-radius: 15px;">
            <div class="modal-body p-4">
                <h5 class="fw-bold text-center mb-4">তথ্য ইনপুট</h5>
                <form id="pensionForm">
                    <input type="hidden" id="editIndex">
                    <div class="mb-3"><label class="small fw-bold">পেনশনারের নাম</label><input type="text" id="pName" class="form-control" required></div>
                    <div class="row mb-3">
                        <div class="col"><label class="small fw-bold">PPO নং</label><input type="text" id="pNo" class="form-control" required></div>
                        <div class="col"><label class="small fw-bold">সিরিয়াল নং</label><input type="text" id="pSi" class="form-control" required></div>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold">অবস্থা</label>
                        <select id="pStatus" class="form-select">
                            <option value="Stocked">Stocked</option>
                            <option value="Delivered">Delivered</option>
                        </select>
                    </div>
                    <div class="mb-4"><label class="small fw-bold">মন্তব্য</label><textarea id="pRemarks" class="form-control" rows="2"></textarea></div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">সংরক্ষণ করুন</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const scriptURL = 'https://script.google.com/macros/s/AKfycbzUr381MXJU3mq9tSmj2aKIIFK4ufZi0POFkiOfguFxtLa6f24tO1Q_gXbNSl2yM8dQ/exec';
    
    let pensioners = JSON.parse(localStorage.getItem('pensionData')) || [];
    let currentPage = 1;
    const recordsPerPage = 12;

    async function fetchFromCloud() {
        document.getElementById('loadingOverlay').style.display = 'flex';
        try {
            const response = await fetch(scriptURL);
            const data = await response.json();
            if (Array.isArray(data)) {
                pensioners = data;
                localStorage.setItem('pensionData', JSON.stringify(pensioners));
                updateUI();
                alert("Cloud Sync Successful!");
            }
        } catch (e) { alert("সিঙ্ক করতে সমস্যা হয়েছে!"); }
        finally { document.getElementById('loadingOverlay').style.display = 'none'; }
    }

    function updateUI() {
        const query = document.getElementById('searchBox').value.toLowerCase();
        
        // Filter logic
        const filtered = pensioners.slice().reverse().filter(p => 
            p.name.toLowerCase().includes(query) || p.ppo.toString().includes(query)
        );

        // Stats update
        document.getElementById('statTotal').innerText = pensioners.length;
        document.getElementById('statStocked').innerText = pensioners.filter(p => p.status === 'Stocked').length;
        document.getElementById('statDelivered').innerText = pensioners.filter(p => p.status === 'Delivered').length;

        // Pagination
        const start = (currentPage - 1) * recordsPerPage;
        const displayData = filtered.slice(start, start + recordsPerPage);
        
        const tbody = document.getElementById('tableBody');
        if(displayData.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="py-5 text-muted">কোনো তথ্য মেলেনি</td></tr>`;
        } else {
            tbody.innerHTML = displayData.map(item => {
                const originalIdx = pensioners.findIndex(p => p.ppo === item.ppo);
                return `<tr>
                    <td>${item.name}</td>
                    <td class="text-primary fw-bold">${item.ppo}</td>
                    <td>${item.si}</td>
                    <td><span class="badge-custom ${item.status === 'Stocked' ? 'status-stocked' : 'status-delivered'}">${item.status}</span></td>
                    <td class="small text-muted">${item.remarks || '-'}</td>
                    <td class="no-print">
                        <button class="btn-action btn-edit" onclick="editEntry(${originalIdx})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-action btn-delete" onclick="deleteEntry(${originalIdx})"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>`;
            }).join('');
        }
        renderPagination(Math.ceil(filtered.length / recordsPerPage));
    }

    function renderPagination(total) {
        const wrapper = document.getElementById('pagination');
        wrapper.innerHTML = "";
        if(total <= 1) return;
        for(let i=1; i<=total; i++) {
            wrapper.innerHTML += `<li class="page-item ${i===currentPage?'active':''}"><a class="page-link" onclick="currentPage=${i};updateUI()">${i}</a></li>`;
        }
    }

    document.getElementById('pensionForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const index = document.getElementById('editIndex').value;
        const data = {
            name: document.getElementById('pName').value,
            ppo: document.getElementById('pNo').value,
            si: document.getElementById('pSi').value,
            status: document.getElementById('pStatus').value,
            remarks: document.getElementById('pRemarks').value
        };

        document.getElementById('loadingOverlay').style.display = 'flex';
        try {
            await fetch(scriptURL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(data) });
            if(index === "") pensioners.push(data);
            else pensioners[index] = data;
            localStorage.setItem('pensionData', JSON.stringify(pensioners));
            updateUI();
            bootstrap.Modal.getInstance(document.getElementById('entryModal')).hide();
        } finally { document.getElementById('loadingOverlay').style.display = 'none'; }
    });

    function editEntry(i) {
        const p = pensioners[i];
        document.getElementById('editIndex').value = i;
        document.getElementById('pName').value = p.name;
        document.getElementById('pNo').value = p.ppo;
        document.getElementById('pSi').value = p.si;
        document.getElementById('pStatus').value = p.status;
        document.getElementById('pRemarks').value = p.remarks;
        new bootstrap.Modal(document.getElementById('entryModal')).show();
    }

    function deleteEntry(i) { if(confirm("মুছে ফেলবেন?")) { pensioners.splice(i, 1); localStorage.setItem('pensionData', JSON.stringify(pensioners)); updateUI(); } }
    function clearForm() { document.getElementById('editIndex').value = ""; document.getElementById('pensionForm').reset(); }
    function exportTableToExcel() { 
        const ws = XLSX.utils.json_to_sheet(pensioners); 
        const wb = XLSX.utils.book_new(); 
        XLSX.utils.book_append_sheet(wb, ws, "Database"); 
        XLSX.writeFile(wb, "Bajitpur_PPO_Records.xlsx"); 
    }

    updateUI();
</script>
</body>
</html>
